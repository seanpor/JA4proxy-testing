{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "panels": [
    {
      "title": "Top 20 JA4 Fingerprints",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "topk(20, sum by (ja4) (rate(ja4proxy_connections_total[1h])))",
          "legendFormat": "{{ja4}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "TLS Version Distribution",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum by (tls_version) (rate(ja4proxy_connections_total[1h]))", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    }
  ],
  "schemaVersion": 38,
  "tags": ["ja4proxy", "tls"],
  "title": "JA4proxy TLS Analysis",
  "uid": "ja4proxy-tls",
  "version": 1
