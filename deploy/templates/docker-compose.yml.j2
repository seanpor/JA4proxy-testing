# docker-compose.yml — JA4proxy Research Honeypot
# Supporting services only. JA4proxy runs as standalone binary.
# Auto-generated by Ansible.

networks:
  {{ ja4proxy_network_frontend }}:
    driver: bridge
  {{ ja4proxy_network_internal }}:
    driver: bridge
    internal: true
  {{ ja4proxy_network_monitoring }}:
    driver: bridge
    internal: true

volumes:
  redis-data:
  prometheus-data:
  loki-data:
  grafana-data:
  caddy-data:
  caddy-config:

services:
  # ── HAProxy: TLS Passthrough ──
  haproxy:
    image: {{ ja4proxy_docker_image_haproxy }}
    container_name: ja4proxy-haproxy
    restart: unless-stopped
    ports:
      - "{{ ja4proxy_haproxy_tls_port }}:{{ ja4proxy_haproxy_tls_port }}"
      - "{{ ja4proxy_haproxy_http_port }}:{{ ja4proxy_haproxy_http_port }}"
      - "{{ ja4proxy_haproxy_stats_port }}:{{ ja4proxy_haproxy_stats_port }}"
    volumes:
      - ./config/haproxy/haproxy.cfg:/usr/local/etc/haproxy/haproxy.cfg:ro
    networks:
      - {{ ja4proxy_network_frontend }}
    deploy:
      resources:
        limits:
          memory: {{ ja4proxy_haproxy_memory_limit }}
          cpus: "{{ ja4proxy_haproxy_cpu_limit }}"
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"

  # ── Redis: State Store ──
  redis:
    image: {{ ja4proxy_docker_image_redis }}
    container_name: ja4proxy-redis
    restart: unless-stopped
    command: >
      redis-server
      --requirepass {{ redis_password }}
      --maxmemory {{ ja4proxy_redis_memory_limit }}
      --maxmemory-policy allkeys-lru
    volumes:
      - redis-data:/data
    networks:
      - {{ ja4proxy_network_internal }}
    deploy:
      resources:
        limits:
          memory: {{ ja4proxy_redis_memory_limit }}
          cpus: "{{ ja4proxy_redis_cpu_limit }}"
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  # ── Caddy: Honeypot Backend ──
  caddy:
    image: {{ ja4proxy_docker_image_caddy }}
    container_name: ja4proxy-honeypot
    restart: unless-stopped
    volumes:
      - ./config/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - ./config/caddy/html:/srv:ro
      - caddy-data:/data
      - caddy-config:/config
    networks:
      - {{ ja4proxy_network_internal }}
    deploy:
      resources:
        limits:
          memory: {{ ja4proxy_caddy_memory_limit }}
          cpus: "{{ ja4proxy_caddy_cpu_limit }}"
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"

  # ── Prometheus: Metrics ──
  prometheus:
    image: {{ ja4proxy_docker_image_prometheus }}
    container_name: ja4proxy-prometheus
    restart: unless-stopped
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--storage.tsdb.retention.time={{ ja4proxy_loki_retention_days }}d'
      - '--web.listen-address=:9090'
    ports:
      - "{{ ja4proxy_prometheus_port }}:9090"
    volumes:
      - ./config/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-data:/prometheus
    networks:
      - {{ ja4proxy_network_monitoring }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    deploy:
      resources:
        limits:
          memory: {{ ja4proxy_prometheus_memory_limit }}
          cpus: "{{ ja4proxy_prometheus_cpu_limit }}"
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"

  # ── Grafana: Dashboards ──
  grafana:
    image: {{ ja4proxy_docker_image_grafana }}
    container_name: ja4proxy-grafana
    restart: unless-stopped
    environment:
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
      - GF_SERVER_HTTP_PORT=3000
      - GF_AUTH_ANONYMOUS_ENABLED=false
    ports:
      - "{{ ja4proxy_grafana_port }}:3000"
    volumes:
      - grafana-data:/var/lib/grafana
      - ./config/grafana/provisioning:/etc/grafana/provisioning:ro
      - ./config/grafana/dashboards:/etc/grafana/dashboards:ro
    networks:
      - {{ ja4proxy_network_monitoring }}
      - {{ ja4proxy_network_frontend }}
    deploy:
      resources:
        limits:
          memory: {{ ja4proxy_grafana_memory_limit }}
          cpus: "{{ ja4proxy_grafana_cpu_limit }}"
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"

  # ── Loki: Log Aggregation ──
  loki:
    image: {{ ja4proxy_docker_image_loki }}
    container_name: ja4proxy-loki
    restart: unless-stopped
    command: -config.file=/etc/loki/loki.yml
    volumes:
      - loki-data:/loki
      - ./config/loki/loki.yml:/etc/loki/loki.yml:ro
    networks:
      - {{ ja4proxy_network_monitoring }}
    deploy:
      resources:
        limits:
          memory: {{ ja4proxy_loki_memory_limit }}
          cpus: "{{ ja4proxy_loki_cpu_limit }}"
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"

  # ── Promtail: Log Shipper ──
  promtail:
    image: {{ ja4proxy_docker_image_promtail }}
    container_name: ja4proxy-promtail
    restart: unless-stopped
    volumes:
      - ./config/promtail/promtail.yml:/etc/promtail/promtail.yml:ro
      - /var/log:/var/log:ro
      - {{ ja4proxy_log_dir }}:{{ ja4proxy_log_dir }}:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - {{ ja4proxy_network_monitoring }}
    command: -config.file=/etc/promtail/promtail.yml
    deploy:
      resources:
        limits:
          memory: {{ ja4proxy_promtail_memory_limit }}
          cpus: "{{ ja4proxy_promtail_cpu_limit }}"
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
