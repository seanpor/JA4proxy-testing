# JA4proxy Configuration — Research Honeypot
# Dial = {{ ja4proxy_dial }} ({{ 'monitor only — no blocking' if ja4proxy_dial == 0 else 'active enforcement' }}). Log everything.
# Auto-generated by Ansible. Edit on the VM and SIGHUP for hot-reload.

proxy:
  mode: passthrough
  bind_host: "127.0.0.1"
  bind_port: {{ ja4proxy_proxy_bind_port }}
  backend_host: "127.0.0.1"
  backend_port: {{ ja4proxy_caddy_internal_port }}
  connection_timeout_ms: 5000
  drain_timeout_seconds: 30

redis:
  host: "127.0.0.1"
  port: 6379
  db: 0
  timeout: 2

security:
  whitelist: []
  blacklist: []
  whitelist_patterns: []
  multi_strategy_policy: "any"

  rate_limit_strategies:
    by_ip:
      enabled: {{ ja4proxy_dial > 0 | lower }}
      thresholds:
        suspicious: 20
        block: 50
        ban: 100
      action: "block"
      ban_duration: 300
    by_ja4:
      enabled: {{ ja4proxy_dial > 0 | lower }}
      thresholds:
        suspicious: 20
        block: 50
        ban: 100
      action: "block"
      ban_duration: 300
    by_ip_ja4_pair:
      enabled: {{ ja4proxy_dial > 0 | lower }}
      thresholds:
        suspicious: 20
        block: 50
        ban: 100
      action: "block"
      ban_duration: 300

geoip:
  country_database_path: "{{ ja4proxy_geoip_dir }}/{{ ja4proxy_geoip_filename }}"
  country_whitelist_enabled: false
  country_blacklist_enabled: false

metrics:
  port: {{ ja4proxy_proxy_metrics_port }}
  bind_host: "0.0.0.0"

logging:
  level: "{{ ja4proxy_log_level }}"
  format: "legacy"
  dual_output: true

tarpit:
  max_concurrent_connections: 500
  max_per_ip: 3
  overflow_action: "block"
  worker_count: 10

monitor_mode:
  dial: {{ ja4proxy_dial }}
  blocking_acknowledged: {{ ja4proxy_dial > 0 | lower }}
  counterfactuals: true

security_policy:
  alpn_browser_bypass_enabled: true
  ja4_whitelist_bypass_enabled: true
  mtls_bypass_enabled: false
  static_ip_allowlist_enabled: false
  ja4_blacklist_bypass_enabled: false
  country_blacklist_bypass_enabled: false
  spamhaus_bypass_enabled: false
  tls_version_bypass_enabled: true

risk_scorer:
  flag: 20
  rate_limit: 35
  tarpit: 55
  block: 70
  ban: 85

abuseipdb:
  enabled: false

blocklists:
  spamhaus:
    enabled: false

beaconing_detector:
  enabled: true
  cv_threshold: 0.8
  max_suspects: 10000

dns_enrichment:
  enabled: false

asn_classifier:
  enabled: true
  datacenter_list_path: ""
  tor_exit_list_path: ""

tcp_analyzer:
  fingerprinting_enabled: true
  session_resumption_tracking: true
  connection_lifespan_tracking: true
  concurrent_connection_tracking: true
  return_visitor_tracking: true
  tls_alert_tracking: true

fingerprinting:
  ja4x_enabled: true
  ja4t_enabled: true
  blacklist_score: 0
