{
    admin off
{% if ja4proxy_deployment_stage == "live" %}
{%   if ja4proxy_acme_staging | default(false) | bool %}
    # Let's Encrypt STAGING — exercises ACME without burning
    # production rate-limit budget. Certs will be browser-invalid.
    acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
{%   else %}
    # Production ACME (Let's Encrypt) — go-live approved
{%   endif %}
{% else %}
    # Self-signed — pre-go-live, bound to 127.0.0.1
    auto_https ignore_loaded_certificates
{% endif %}
}

{{ ja4proxy_domain }} {
{% if ja4proxy_deployment_stage == "live" %}
    tls {
        # ACME-issued certificate (staging or production based on
        # acme_ca above)
    }
{% else %}
    tls internal
{% endif %}

    log {
        output stdout
        format json
    }

    root * /srv
    file_server

    @submit path /submit
    handle @submit {
        respond "Submission received and discarded for research.\n" 200
    }

    encode gzip
}

http://{{ ja4proxy_domain }} {
    redir https://{host}{uri} 301
}
