{
    admin off
{% if ja4proxy_deployment_stage == "live" %}
    # Production ACME (Let's Encrypt) — go-live approved
{% else %}
    # Staging ACME / self-signed — DO NOT use in production
    auto_https ignore_loaded_certificates
{% endif %}
}

{{ ja4proxy_domain }} {
{% if ja4proxy_deployment_stage == "live" %}
    tls {
        # Production Let's Encrypt certificates
    }
{% else %}
    tls internal
{% endif %}

    log {
        output stdout
        format json
    }

    root * /srv
    file_server

    @submit path /submit
    handle @submit {
        respond "Submission received and discarded for research.\n" 200
    }

    encode gzip
}

http://{{ ja4proxy_domain }} {
    redir https://{host}{uri} 301
}
